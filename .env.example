# Provided automatically by Railway's PostgreSQL plugin — do not set manually on Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Only needed for local development (ignored when DATABASE_URL is set)
DB_PASSWORD=your_db_password

# Admin dashboard password
ADMIN_PASSWORD=your_admin_password

# Gmail app password for sending booking emails
EMAIL_PASSWORD=your_gmail_app_password

# Public URL of your app — update to your Railway domain after first deploy
BASE_URL=https://your-app.up.railway.app
